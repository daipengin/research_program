# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
.uv-cache/

# Research-generated data and figures
data/runs/*
data/run/*
data/aggregated/*
data/archives/*
outputs/figures/*
outputs/reports/*
!data/runs/.gitkeep
!data/run/.gitkeep
!data/aggregated/.gitkeep
!data/archives/.gitkeep
!data/archives/temp/
data/archives/temp/*
!data/archives/temp/.gitkeep
!outputs/figures/.gitkeep
!outputs/reports/.gitkeep
!outputs/reports/simulation_jobs/
outputs/reports/simulation_jobs/*
!outputs/reports/simulation_jobs/.gitkeep
!outputs/reports/graph_creation_jobs/
outputs/reports/graph_creation_jobs/*
!outputs/reports/graph_creation_jobs/.gitkeep
